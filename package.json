{
  "name": "davecarter-dev-site",
  "version": "1.0.0",
  "description": "David Garcia Personal site",
  "main": "src/index.js",
  "scripts": {
    "co": "npx sui-mono commit",
    "start": "npx sui-bundler dev",
    "build": "npx sui-bundler build -C",
    "postbuild": "cp -R static public",
    "now-build": "npm run build"
  },
  "keywords": [],
  "author": "David G.",
  "license": "ISC",
  "dependencies": {
    "@s-ui/bundler": "5",
    "@s-ui/lint": "2",
    "react": "16.8.2",
    "react-dom": "16.8.2"
  },
  "sui-bundler": {
    "offline": {
      "whitelist": [
        "::all::"
      ],
      "runtime": [
        {
          "urlPattern": "fonts\\.googleapis\\.com",
          "handler": "cacheFirst"
        },
        {
          "urlPattern": "static\\/images",
          "handler": "cacheFirst"
        }
      ]
    }
  },
  "eslintConfig": {
    "extends": [
      "./node_modules/@s-ui/lint/eslintrc.js"
    ]
  },
  "sasslintConfig": "./node_modules/@s-ui/lint/sass-lint.yml",
  "devDependencies": {
    "@s-ui/mono": "1"
  }
}
